na = "NA"),
sep = list(int = ": ",
ext = "; ",
conf = "; "),
ci = list(lim = "[",
label = "95%CI"),
font = list(alpha = "bahnschrift",
digit = "ubuntu"),
palette = list(base = "#999999",
cold = c("#E1F6FF", "#0099CC"),
warm = c("#f5E3E0", "#BC3C29"))) |>
purrr::list_modify(!!!dots)
if (lang == "fr") .set$sep <- purrr::map(.set$sep, ~ paste("", .))
switch(.set$ci$lim,
"[" = .lim <- c("[", "]"),
"(" = .lim <- c("(", ")"))
.set$ci <-
list(label = glue::glue("{.lim[1]}{.set$ci$label}{.lim[2]}"),
data = glue::glue("{.lim[1]}{{conf.low}}{.set$sep$conf}{{conf.high}}{.lim[2]}"))
assign("opts",
list(set = .set) |>
purrr::list_modify(.dots),
envir = .GlobalEnv)
}
opts_test()
